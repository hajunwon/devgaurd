<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!--
        Exclude app preferences from cloud backup and device-to-device transfer.
        Language preference and scan state should not migrate across devices —
        each device is inspected independently.
    -->
    <cloud-backup>
        <exclude domain="sharedpref" path="devguard_prefs"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="devguard_prefs"/>
    </device-transfer>
</data-extraction-rules>
