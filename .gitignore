# Gradle
.gradle/
build/

# Local configuration (machine-specific, never commit)
local.properties

# IDE — per-file exclusions managed in .idea/.gitignore
*.iml

# NDK build artifacts
.externalNativeBuild/
.cxx/
obj/

# Android packaging artifacts
captures/
*.ap_
*.aab

# Release signing keys — NEVER commit these
*.jks
*.keystore
keystore/

# OS metadata
.DS_Store
Thumbs.db

# Git merge artifacts
*.orig
